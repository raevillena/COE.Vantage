# =============================================================================
# COE.Vantage Backend – Environment sample
# =============================================================================
# Copy this file to .env and fill in values. Do not commit .env or .env.local.
# Optional: use .env.local to override values locally (e.g. for development).
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# PostgreSQL connection URL.
DATABASE_URL=postgresql://user:password@localhost:5432/coe_vantage

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Used for refresh tokens and password-reset tokens. Default below if not set.
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# JWT (required)
# -----------------------------------------------------------------------------
# Use long, random strings (e.g. 32+ chars). Keep secret in production.
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
# Access token lifetime (e.g. 15m, 1h). Refresh token lifetime (e.g. 7d).
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# -----------------------------------------------------------------------------
# Frontend / CORS
# -----------------------------------------------------------------------------
# Origin of the frontend app (for CORS and redirects). Used as base for reset links if RESET_PASSWORD_BASE_URL is not set.
FRONTEND_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Password reset (optional)
# -----------------------------------------------------------------------------
# Base URL for password-reset links in emails. If unset, FRONTEND_ORIGIN is used.
# Example (production): https://app.example.com
# RESET_PASSWORD_BASE_URL=

# SMTP: required only if you want to send reset emails. If all SMTP_* are unset, the reset link is logged to the server console (useful for development).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=COE.Vantage <noreply@example.com>

# -----------------------------------------------------------------------------
# OpenAI (optional)
# -----------------------------------------------------------------------------
# Only needed if using AI-related features (e.g. curriculum extraction).
# OPENAI_API_KEY=
